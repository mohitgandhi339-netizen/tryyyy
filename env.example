# ================================================================
#  JUSTDOWOW — Required Environment Variables
#  Add these in: Vercel Dashboard → Project → Settings → Environment Variables
#  Do NOT commit real values to GitHub — this file is just documentation.
# ================================================================

# OpenAI API Key (required for /api/ai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key-here...

# ElevenLabs API Key (required for /api/tts voice output)
# Get from: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID (optional — defaults to Rachel if not set)
# Browse voices at: https://elevenlabs.io/voice-lab
# Rachel (warm, professional):  21m00Tcm4TlvDq8ikWAM
# Domi  (clear Hindi/Hinglish): AZnzlk1XvdvUeBnXmlld
# Elli  (natural Indian-EN):    MF3mGyEYCl7XYWbV9V6O
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
